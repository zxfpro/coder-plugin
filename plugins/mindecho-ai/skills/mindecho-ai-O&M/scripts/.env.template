# 部署环境变量配置模板
# 复制此文件为 .env 并填写实际值

# Docker 镜像标签（可选）
# 默认使用 latest 标签，也可以指定具体版本号
# 例如: shikongai-registry.cn-beijing.cr.aliyuncs.com/shikongai/mindecho_ai:20260227-43
IMAGE_TAG=shikongai-registry.cn-beijing.cr.aliyuncs.com/shikongai/mindecho_ai:latest

# 服务器配置（可选，覆盖脚本中的默认值）
# SERVER_USER=root
# SERVER_HOST=39.96.146.47
# SERVER_DIR=/root/diglife_docker/test

# Docker 镜像仓库（可选）
# REGISTRY=shikongai-registry.cn-beijing.cr.aliyuncs.com/shikongai/mindecho_ai

# 应用配置（供参考）
# 这些值在 docker-compose.yml 中定义，此处仅作文档参考
# QDRANT_HOST=qdrant
# QDRANT_PORT=5333
# COLLECTION_NAME=diglife
# SIMILARITY_TOP_K=10
# SIMILARITY_CUTOFF=0.9834
